# Routes
# This file defines all application routes (Higher priority routes first)
# ~~~~

# An example controller showing a sample home page
GET           /                                      controllers.HomeController.index()

# Map static resources from the /public folder to the /assets URL path
GET           /assets/*file                          controllers.Assets.versioned(path="/public", file: Asset)
GET           /card/:id/transactions                 controllers.CardController.getAllTransaction(id: Long)
GET           /card/:cardId/totalTransactions        controllers.CardController.getTotalTransactionAmount(cardId: Long)
GET           /cards                                 controllers.CardController.showAllCards
GET           /card/:cardId/statement                controllers.BillingController.generateMonthlyStatements(cardId: Long)
GET           /card/:cardId/availableLimit           controllers.CardController.getAvailableLimit(cardId : Long)
GET           /transactions                          controllers.CardController.searchTransactions()
GET           /transactions/download/csv             controllers.CardController.downloadCSV()
GET           /transactions/download/pdf             controllers.CardController.downloadPDF()
GET           /card/:cardId/rewardBalance            controllers.RewardController.rewardBalance(cardId : Long)
GET           /aiAnalysis                            controllers.LogController.analyzeLogs()

POST          /signup                                controllers.UserController.signUp()
POST          /signin                                controllers.UserController.signIn()
POST          /card/createCard                       controllers.CardController.addCard()
POST          /completePayment                       controllers.CardController.completePayment()
POST          /forgot-password                       controllers.UserController.forgotPassword()
POST          /reset-password                        controllers.UserController.resetPassword()
POST          /change-password                       controllers.UserController.changePassword()
POST          /payment/:cardNumber/payBill           controllers.PaymentController.payBill(cardNumber : String)
POST          /addLogs                               controllers.LogController.addLogs()

PUT           /card/:cardId/block                    controllers.CardController.blockCard(cardId : Long)
PUT           /card/:cardId/unblock                  controllers.CardController.unBlockCard(cardId : Long)
PUT           /profile/update                        controllers.UserController.updateProfile()

DELETE        /card/:cardId                          controllers.CardController.deleteCard(cardId : Long)