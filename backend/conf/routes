# Routes
# This file defines all application routes (Higher priority routes first)
# ~~~~

# An example controller showing a sample home page
GET           /api/                                      controllers.HomeController.index()

# Map static resources from the /public folder to the /assets URL path
GET           /api/assets/*file                          controllers.Assets.versioned(path="/public", file: Asset)
GET           /api/card/:id/transactions                 controllers.CardController.getAllTransaction(id: Long)
GET           /api/card/:cardId/totalTransactions        controllers.CardController.getTotalTransactionAmount(cardId: Long)
GET           /api/cards                                 controllers.CardController.showAllCards
GET           /api/card/:cardId/statement                controllers.BillingController.generateMonthlyStatements(cardId: Long)
GET           /api/card/:cardId/availableLimit           controllers.CardController.getAvailableLimit(cardId : Long)
GET           /api/transactions                          controllers.CardController.searchTransactions()
GET           /api/transactions/download/csv             controllers.CardController.downloadCSV()
GET           /api/transactions/download/pdf             controllers.CardController.downloadPDF()
GET           /api/card/:cardId/rewardBalance            controllers.RewardController.rewardBalance(cardId : Long)
GET           /api/aiAnalysis                            controllers.LogController.analyzeLogs()

POST          /api/signup                                controllers.UserController.signUp()
POST          /api/signin                                controllers.UserController.signIn()
POST          /api/card/createCard                       controllers.CardController.addCard()
POST          /api/completePayment                       controllers.CardController.completePayment()
POST          /api/forgot-password                       controllers.UserController.forgotPassword()
POST          /api/reset-password                        controllers.UserController.resetPassword()
POST          /api/change-password                       controllers.UserController.changePassword()
POST          /api/payment/:cardNumber/payBill           controllers.PaymentController.payBill(cardNumber : String)
POST          /api/addLogs                               controllers.LogController.addLogs()

PUT           /api/card/:cardId/block                    controllers.CardController.blockCard(cardId : Long)
PUT           /api/card/:cardId/unblock                  controllers.CardController.unBlockCard(cardId : Long)
PUT           /api/profile/update                        controllers.UserController.updateProfile()

DELETE        /api/card/:cardId                          controllers.CardController.deleteCard(cardId : Long)